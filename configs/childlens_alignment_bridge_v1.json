{
  "schema_version": "childlens-alignment-bridge-preflight-v1.0.0",
  "status": "FROZEN_BEFORE_SPLIT_ASSIGNMENT_OR_DEVELOPMENT_OUTCOME_INSPECTION",
  "scientific_role": "PROVISIONAL_DEVELOPMENTAL_CALIBRATION_AGES_3_TO_5",
  "empirical_source": "CHILDLENS_ONLY",
  "excluded_empirical_ancestry": [
    "AEA",
    "BABYVIEW"
  ],
  "objective": "Test whether a continuous utterance-frame alignment measurement is stable and distinguishes real ChildLens pairings from matched shuffled and within-recording time-shifted controls before any simulator fitting.",
  "scope": {
    "participant_distinct_recordings": 30,
    "development_recordings": 8,
    "locked_recordings": 22,
    "development_by_historical_acquisition_cohort": {
      "original": 4,
      "extension": 4
    },
    "split_unit": "participant",
    "split_method": "sha256(protocol_sha256|participant_key), ascending within acquisition cohort",
    "locked_outcomes_available_during_tuning": false,
    "simulator_generation_allowed": false,
    "learner_training_allowed": false
  },
  "source_bindings": {
    "childlens_doi": "10.17617/4.fe",
    "public_snapshot_commit": "4856662653b2fa183e53268d088cffba02a33443",
    "combined_selection_sha256": "da1b5f7b0ff0e4461a1ac6a9b0ca5cc29f5aa0bbe7b0f28a8a0c781a1e084b01",
    "prior_terminal_record_sha256": "bd522ca49117b9bfb7c9b6643e06daf03d0f4c7b21a870b760d6a7bd84755c90",
    "egobabyvlm_commit": "224621caf0628270b6115845ac75a65b984234a3"
  },
  "measurement_route": {
    "primary_asr": {
      "instrument": "Qwen3-ASR-1.7B plus Qwen3-ForcedAligner-0.6B",
      "asr_revision_prefix": "7278e",
      "aligner_revision_prefix": "c7cbf",
      "language": "de",
      "role": "FIXED_LOCAL_MEASUREMENT_INSTRUMENT_NOT_ACQUISITION_LEARNER"
    },
    "sole_sensitivity": {
      "instrument": "whisper.cpp-v1.9.1 large-v3-turbo unquantized DTW",
      "source_revision": "f049fff95a089aa9969deb009cdd4892b3e74916",
      "model_revision": "5359861c739e955e79d9a303bcbc70fb988958b1",
      "language_mode": "auto",
      "role": "MODEL_MODEL_SENSITIVITY_NOT_GROUND_TRUTH"
    },
    "alignment_instrument": {
      "implementation": "OpenCLIP normalized image-text cosine behind an EgoBabyVLM-compatible ID-preserving wrapper",
      "model": "xlm-roberta-base-ViT-B-32",
      "pretrained": "laion5b_s13b_b90k",
      "language": "German retained without translation",
      "weights_role": "FIXED_PRETRAINED_MEASUREMENT_INSTRUMENT_ONLY"
    },
    "new_asr_or_alignment_model_shopping_allowed": false,
    "generative_vlm_referential_labels_allowed": false,
    "translation_allowed": false
  },
  "utterance_and_frame_rules": {
    "candidate_source": "released timed ChildLens speech bouts intersected with the frozen 60-second-per-recording measurement sample",
    "released_bouts_are_utterance_truth": false,
    "primary_utterance_source": "primary ASR forced-aligned utterance hypotheses",
    "minimum_utterance_seconds": 0.3,
    "maximum_utterance_seconds": 12.0,
    "minimum_normalized_text_characters": 2,
    "frame_rate_hz": 1.0,
    "frame_timestamp": "midpoint convention t=(index-0.5)/fps, following EgoBabyVLM manifest preprocessing",
    "frame_context_seconds_each_side": 1.0,
    "video_embedding_aggregation": "mean of L2-normalized frame embeddings, then L2 normalize",
    "text_embedding_aggregation": "one L2-normalized embedding per retained utterance"
  },
  "controls": {
    "shuffled": {
      "unit": "whole utterance text",
      "donor_excludes_same_participant": true,
      "derangement_required": true,
      "matching_order": [
        "activity_family_plus_duration_quartile_plus_speech_density_tertile",
        "duration_quartile_plus_speech_density_tertile",
        "duration_quartile",
        "global"
      ],
      "deterministic_order": "sha256(protocol_sha256|utterance_key)"
    },
    "time_shifted": {
      "unit": "frame window",
      "offset_seconds": 15.0,
      "direction": "deterministic sign from sha256(protocol_sha256|utterance_key)",
      "wrap_allowed": false,
      "overlap_with_real_window_allowed": false,
      "unavailable_rows": "excluded identically from real, shuffled, and shifted comparison"
    },
    "same_frame_and_text_inventory_across_arms": true
  },
  "measurement_vector": {
    "model_independent": [
      "speech_bout_duration_seconds",
      "speech_seconds_per_sample_minute",
      "speech_bout_density_per_minute",
      "inter_bout_gap_seconds",
      "activity_duration_seconds",
      "activity_recurrence_per_minute",
      "speech_activity_overlap_fraction",
      "candidate_utterance_density_per_minute",
      "grayscale_frame_difference_motion_proxy",
      "adjacent_frame_persistence_proxy",
      "scene_change_rate_at_fixed_difference_threshold",
      "coarse_activity_share",
      "coarse_location_share"
    ],
    "model_based": [
      "real_utterance_frame_cosine",
      "matched_shuffled_cosine",
      "within_recording_time_shifted_cosine",
      "participant_mean_real_minus_shuffled",
      "participant_mean_real_minus_shifted"
    ],
    "scene_change_mean_absolute_grayscale_threshold": 0.2
  },
  "ordered_gates": {
    "G0_governance_and_binding": {
      "all_restricted_files_owner_private": true,
      "all_30_sample_files_present_and_hash_bound": true,
      "participant_distinct": true,
      "pass_required_before": "development_measurement"
    },
    "G1_development_asr_coverage": {
      "primary_nonempty_item_fraction_min": 0.9,
      "sensitivity_nonempty_item_fraction_min": 0.9,
      "primary_usable_utterances_min": 24,
      "usable_utterance_fraction_of_primary_min": 0.6,
      "pass_required_before": "development_alignment_scoring"
    },
    "G2_development_german_and_model_model_stability": {
      "primary_german_item_fraction_min": 0.8,
      "primary_sensitivity_language_agreement_min": 0.8,
      "participant_median_normalized_character_similarity_min": 0.55,
      "participant_cluster_bootstrap_90pct_lower_min": 0.4,
      "participant_median_boundary_f1_min": 0.4,
      "participant_cluster_bootstrap_boundary_f1_90pct_lower_min": 0.25,
      "historical_risk_disclosure": "A pre-existing all-30 aggregate reported poor Qwen-vs-Whisper WER/CER and boundary F1. These thresholds demand modest reproducibility and were frozen before computing the new development split.",
      "pass_required_before": "development_alignment_scoring"
    },
    "G3_development_alignment_mechanical": {
      "retained_utterances_min": 24,
      "participants_with_scored_rows_min": 5,
      "missing_or_substituted_row_fraction_max": 0.05,
      "pass_required_before": "locked_evaluation"
    },
    "G4_locked_alignment_effect": {
      "analysis_unit": "participant",
      "cluster_bootstrap_replicates": 10000,
      "cluster_bootstrap_confidence": 0.9,
      "sign_flip_permutation_replicates": 100000,
      "fixed_seed": 20260706,
      "minimum_mean_cosine_lift_each_control": 0.01,
      "lower_confidence_bound_must_exceed": 0.0,
      "one_sided_p_max_each_control": 0.05,
      "intersection_union_rule": "both shuffled and time-shifted criteria must pass"
    }
  },
  "stop_rules": [
    "Stop without locked scoring if G0, G1, G2, or G3 fails.",
    "Stop if German ASR/text/alignment is scientifically unusable; do not add or swap models post hoc.",
    "Stop if either locked control comparison fails; do not fit a simulator.",
    "Stop if privacy-safe K>=5 aggregate reporting cannot expose both control envelopes.",
    "Never reinterpret the failed Qwen3-VL/Gemma categorical branch or relax its frozen gates."
  ],
  "uncertainty": {
    "development": "participant-cluster bootstrap, 10000 resamples, 90% interval, fixed seed 20260706",
    "locked": "participant-cluster bootstrap plus one-sided participant sign-flip randomization, fixed seed",
    "development_results_are_not_confirmatory": true
  },
  "privacy": {
    "restricted_outputs": [
      "paths",
      "filenames",
      "participant_session_item_keys",
      "exact_intervals",
      "transcripts",
      "frames_audio",
      "embeddings_logits_row_scores"
    ],
    "public_minimum_cell_size": 5,
    "complementary_suppression": true,
    "public_artifacts": "nonidentifying aggregate evidence and cryptographic receipts only",
    "retention_review_deadline": "2027-07-31"
  },
  "decision_options_if_stopped": [
    "Stop the lexical alignment bridge and retain only model-independent ChildLens distribution calibration.",
    "Obtain authorized qualified German validation under a separately frozen protocol.",
    "Preregister one new ASR/alignment route in a new protocol; do not model-shop or fall back to synthetic-only evidence.",
    "Expand ChildLens only if a separately justified identifiability or K-safe aggregation requirement is established."
  ]
}
